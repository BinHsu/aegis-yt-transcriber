#!/usr/bin/env bash
# aegis-yt-transcriber — one-liner wrapper.
#   ./transcribe "https://www.youtube.com/watch?v=VIDEO_ID" [--timestamps] [--model REPO] [--lang en]
# First run bootstraps a local .venv from requirements.txt; later runs reuse it.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV="$DIR/.venv"

if [ "$#" -eq 0 ]; then
  echo "usage: ./transcribe \"<youtube-url>\" [--timestamps] [--model REPO] [--lang en]" >&2
  exit 2
fi

if [ ! -x "$VENV/bin/python" ]; then
  echo ">> first run: creating .venv and installing deps (one-time)..." >&2
  python3 -m venv "$VENV"
  "$VENV/bin/python" -m pip install --quiet --upgrade pip
  "$VENV/bin/python" -m pip install --quiet -r "$DIR/requirements.txt"
fi

exec "$VENV/bin/python" "$DIR/yt2txt.py" "$@"
